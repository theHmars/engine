# Sandbox Test Configuration

# Enable test mode? (true/false)
TEST_MODE_ENABLED=true

# Pipeline Scope: "all", "local", "national", "global"
PIPELINE_SCOPE=all

# Number of articles to process per scope
ARTICLES_PER_SCOPE=1

# Test Quota Overrides (Allows testing the AI Curator selection logic without generating 30 articles)
TEST_QUOTA_NORMAL=2
TEST_QUOTA_HIGH=4

# Use real AI Agents to generate articles? (true/false)
# If false, it completely skips the engine and instantly generates valid markdown files at the end of the pipeline.
TEST_MODE_AGENTS=true

# Inject Semantic Duplicate Mock Data? (true/false)
# If true (and TEST_MODE_AGENTS=true), this skips RSS scraping and injects specific trick-data into the engine 
# (semantic duplicates and covered URLs) to test if the AI Deduplicator and History Manager catch them.
TEST_MODE_MOCK_DATA=false

# Stream LLM generation live to the terminal? (true/false)
# Watch the AI type out its thoughts and JSON payloads token-by-token in real time.
TEST_MODE_STREAM=true

# Render Mocking Options:
# "success"      -> Simulates a perfect build.
# "build_failed" -> Hook works, but build crashes on Render. Triggers quarantine rollback.
# "timeout"      -> Hook works, but polling times out. Triggers quarantine rollback.
# "404"          -> Hook URL is invalid/down. Fails instantly.
TEST_MODE_RENDER=success

# Social Media Mocking Options:
# "true"  -> Dry-run (prints the Facebook payload to the terminal)
# "false" -> Danger: Actually posts to Facebook!
TEST_MODE_SOCIAL=true
